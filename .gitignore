# Python cache files
__pycache__/
*.pyc
*.pyo
*.pyd

# Node modules
node_modules/

# Generated per-dataset model caches (results/*.pkl) and per-upload-hash
# result artifacts. The unhashed default-dataset reference results (e.g.
# xgboost_cv_metrics.json, xgboost_metrics.txt) are NOT covered by this and
# stay tracked -- only the *_<md5hash>.* variants generated per uploaded
# dataset, which multiply indefinitely and shouldn't be committed.
python_models/*/results/*.pkl
python_models/*/results/*_????????????????????????????????.csv
python_models/*/results/*_????????????????????????????????.txt
python_models/*/results/*_????????????????????????????????.json
